{
  "name": "inzozi-nziza-server",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.9.2",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../prisma/schema.prisma",
    "db:seed": "prisma db seed --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "6.9.0",
    "argon2": "^0.43.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.17",
    "prisma": "6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "../prisma/schema.prisma",
    "seed": "tsx ../prisma/seed.ts"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "argon2@0.43.1": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true
  }
}
