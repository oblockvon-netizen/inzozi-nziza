# Neon PostgreSQL
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/inzozi_nziza?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/inzozi_nziza?sslmode=require"

# Server
NODE_ENV="development"
PORT=3000
API_URL="http://localhost:3000"
APP_URL="http://localhost:8080"

# JWT (use long random strings in production)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"

# Cookies
COOKIE_SECRET="change-me-cookie-secret-min-32-chars"

# Auth tuning
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1

# SMTP (optional — emails log to console when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Inzozi Nziza <noreply@inzozi.rw>"

# Bootstrap admin — created automatically when you run `npm run db:seed`
# Then sign in at /auth/login (no manual DB edits needed)
BOOTSTRAP_ADMIN_EMAIL=admin@inzozi.local
BOOTSTRAP_ADMIN_PASSWORD=AdminPass123!
BOOTSTRAP_ADMIN_NAME=Site Admin
BOOTSTRAP_ADMIN_PHONE=+250788000000
