// Inzozi Nziza — Prisma schema (Supabase replacement)
// Target: PostgreSQL on Neon
// See ERD.md for entity relationships and MIGRATION_PLAN.md for rollout steps.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AppRole {
  ADMIN
  USER

  @@map("app_role")
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE

  @@map("member_status")
}

enum ContributionStatus {
  PENDING
  COMPLETED
  FAILED

  @@map("contribution_status")
}

enum LoanStatus {
  PENDING
  APPROVED
  DENIED
  DISBURSED
  REPAID
  DEFAULTED

  @@map("loan_status")
}

enum LoanPaymentStatus {
  PENDING
  PAID
  OVERDUE

  @@map("loan_payment_status")
}

enum FineStatus {
  PENDING
  PAID
  CANCELLED

  @@map("fine_status")
}

enum ApprovalRequestType {
  GRANT_ADMIN
  APPROVE_MEMBER
  APPROVE_LOAN
  DENY_LOAN
  DELETE_USER
  DEACTIVATE_USER
  CONTRIBUTION_CORRECTION
  CANCEL_FINE

  @@map("approval_request_type")
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@map("approval_request_status")
}

enum NotificationType {
  MEMBER_APPROVED
  MEMBER_REJECTED
  LOAN_SUBMITTED
  LOAN_APPROVED
  LOAN_DENIED
  LOAN_PAYMENT_DUE
  LOAN_DEFAULTED
  CONTRIBUTION_RECORDED
  FINE_ISSUED
  FINE_PAID
  FINE_CANCELLED
  APPROVAL_REQUEST_CREATED
  APPROVAL_REQUEST_RESOLVED
  SYSTEM

  @@map("notification_type")
}

// ---------------------------------------------------------------------------
// Auth & identity (replaces Supabase auth.users + profiles)
// ---------------------------------------------------------------------------

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  email                String    @unique @db.VarChar(255)
  passwordHash         String    @map("password_hash")
  emailVerifiedAt      DateTime? @map("email_verified_at") @db.Timestamptz
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until") @db.Timestamptz
  lastActiveAt         DateTime? @map("last_active_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  profile                     Profile?
  userRoles                   UserRole[]
  contributions               Contribution[]           @relation("ContributionMember")
  contributionsRecorded       Contribution[]           @relation("ContributionRecorder")
  loans                       Loan[]                   @relation("LoanMember")
  loansReviewed               Loan[]                   @relation("LoanReviewer")
  fines                       Fine[]                   @relation("FineMember")
  finesIssued                 Fine[]                   @relation("FineIssuer")
  finePaymentsRecorded        FinePayment[]            @relation("FinePaymentRecorder")
  loanPaymentsRecorded        LoanPayment[]            @relation("LoanPaymentRecorder")
  refreshTokens               RefreshToken[]
  notifications               Notification[]
  auditLogs                   AuditLog[]               @relation("AuditActor")
  approvalRequestsCreated     AdminApprovalRequest[]   @relation("ApprovalRequester")
  approvalRequestsReviewed    AdminApprovalRequest[]   @relation("ApprovalReviewer")
  approvalRequestsTargetUser  AdminApprovalRequest[]   @relation("ApprovalTargetUser")

  @@index([email])
  @@index([lastActiveAt])
  @@map("users")
}

model Profile {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @unique @map("user_id") @db.Uuid
  fullName   String       @map("full_name")
  phone      String?
  isApproved Boolean      @default(false) @map("is_approved")
  status     MemberStatus @default(PENDING)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isApproved])
  @@index([status])
  @@map("profiles")
}

// ---------------------------------------------------------------------------
// Roles (replaces Supabase user_roles + app_role enum)
// ---------------------------------------------------------------------------

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      AppRole  @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Contributions (105,000 RWF monthly requirement)
// ---------------------------------------------------------------------------

model Contribution {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  amount          Decimal            @db.Decimal(12, 2)
  paymentDate     DateTime           @default(now()) @map("payment_date") @db.Timestamptz
  status          ContributionStatus @default(PENDING)
  referenceNumber String?            @map("reference_number")
  recordedById    String?            @map("recorded_by_id") @db.Uuid
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user       User  @relation("ContributionMember", fields: [userId], references: [id], onDelete: Cascade)
  recordedBy User? @relation("ContributionRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([paymentDate])
  @@index([status])
  @@map("contributions")
}

// ---------------------------------------------------------------------------
// Loans & loan payments
// ---------------------------------------------------------------------------

model Loan {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @map("user_id") @db.Uuid
  amount            Decimal    @db.Decimal(12, 2)
  purpose           String
  status            LoanStatus @default(PENDING)
  appliedAt         DateTime   @default(now()) @map("applied_at") @db.Timestamptz
  approvedAt        DateTime?  @map("approved_at") @db.Timestamptz
  reviewedById      String?    @map("reviewed_by_id") @db.Uuid
  adminNotes        String?    @map("admin_notes")
  dueDate           DateTime?  @map("due_date") @db.Timestamptz
  interestRate      Decimal?   @map("interest_rate") @db.Decimal(5, 2)
  totalWithInterest Decimal?   @map("total_with_interest") @db.Decimal(12, 2)
  amountPaid        Decimal    @default(0) @map("amount_paid") @db.Decimal(12, 2)
  lastPaymentDate   DateTime?  @map("last_payment_date") @db.Timestamptz
  installmentsCount Int        @default(3) @map("installments_count")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user              User              @relation("LoanMember", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy        User?             @relation("LoanReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  payments          LoanPayment[]
  approvalRequests  AdminApprovalRequest[]

  @@index([userId])
  @@index([status])
  @@index([appliedAt])
  @@map("loans")
}

model LoanPayment {
  id                String            @id @default(uuid()) @db.Uuid
  loanId            String            @map("loan_id") @db.Uuid
  amount            Decimal           @db.Decimal(12, 2)
  dueDate           DateTime          @map("due_date") @db.Timestamptz
  paidAmount        Decimal           @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paidDate          DateTime?         @map("paid_date") @db.Timestamptz
  status            LoanPaymentStatus @default(PENDING)
  installmentNumber Int?              @map("installment_number")
  notes             String?
  recordedById      String?           @map("recorded_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  loan       Loan  @relation(fields: [loanId], references: [id], onDelete: Cascade)
  recordedBy User? @relation("LoanPaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([loanId])
  @@index([dueDate])
  @@index([status])
  @@map("loan_payments")
}

// ---------------------------------------------------------------------------
// Fines & fine payments
// ---------------------------------------------------------------------------

model Fine {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  amount     Decimal    @db.Decimal(12, 2)
  amountPaid Decimal    @default(0) @map("amount_paid") @db.Decimal(12, 2)
  reason     String
  status     FineStatus @default(PENDING)
  issuedAt   DateTime   @default(now()) @map("issued_at") @db.Timestamptz
  paidAt     DateTime?  @map("paid_at") @db.Timestamptz
  issuedById String?    @map("issued_by_id") @db.Uuid
  adminNotes String?    @map("admin_notes")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user             User                   @relation("FineMember", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy         User?                  @relation("FineIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  payments         FinePayment[]
  approvalRequests AdminApprovalRequest[]

  @@index([userId])
  @@index([status])
  @@index([issuedAt])
  @@map("fines")
}

model FinePayment {
  id           String   @id @default(uuid()) @db.Uuid
  fineId       String   @map("fine_id") @db.Uuid
  amount       Decimal  @db.Decimal(12, 2)
  paidAt       DateTime @default(now()) @map("paid_at") @db.Timestamptz
  recordedById String?  @map("recorded_by_id") @db.Uuid
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  fine       Fine  @relation(fields: [fineId], references: [id], onDelete: Cascade)
  recordedBy User? @relation("FinePaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([fineId])
  @@index([paidAt])
  @@map("fine_payments")
}

// ---------------------------------------------------------------------------
// Two-admin approval workflow
// ---------------------------------------------------------------------------

model AdminApprovalRequest {
  id           String                @id @default(uuid()) @db.Uuid
  type         ApprovalRequestType
  status       ApprovalRequestStatus @default(PENDING)
  requesterId  String                @map("requester_id") @db.Uuid
  reviewerId   String?               @map("reviewer_id") @db.Uuid
  targetUserId String?               @map("target_user_id") @db.Uuid
  targetLoanId String?               @map("target_loan_id") @db.Uuid
  targetFineId String?               @map("target_fine_id") @db.Uuid
  payload      Json                  @default("{}")
  reviewNotes  String?               @map("review_notes")
  expiresAt    DateTime?             @map("expires_at") @db.Timestamptz
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt   DateTime?             @map("resolved_at") @db.Timestamptz

  requester  User   @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer   User?  @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  targetUser User?  @relation("ApprovalTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetLoan Loan?  @relation(fields: [targetLoanId], references: [id], onDelete: SetNull)
  targetFine Fine?  @relation(fields: [targetFineId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([requesterId])
  @@index([reviewerId])
  @@index([createdAt])
  @@map("admin_approval_requests")
}

// ---------------------------------------------------------------------------
// Audit & notifications
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  readAt    DateTime?        @map("read_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Sessions (refresh tokens for HttpOnly cookie auth)
// ---------------------------------------------------------------------------

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
